# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ── Stream keys ────────────────────────────────────────────────────────────────
CODER_STREAM_KEY=
MANAGER_STREAM_KEY=
TESTER_STREAM_KEY=
# A/B coding-backend coders (docs/coding_backend.md) — default to rtmp-preview
CODER_NATIVE_STREAM_KEY=
CODER_OPENCODE_STREAM_KEY=
CODER_AIDER_STREAM_KEY=
STREAM_RTMP_URL=

# ── Git (coding backends) ──────────────────────────────────────────────────────
# Leave empty for local-commits-only mode. Set once the local git server is up;
# git_client.py will start pushing (PR API integration is queued behind this).
GIT_SERVER_URL=

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=
# Required only when a worker's config sets llm.provider: claude
ANTHROPIC_API_KEY=

# ── Kafka (message bus) ────────────────────────────────────────────────────────
# Point at an existing broker (e.g. a shared deployment host). For a fully
# self-contained standalone deployment with no external Kafka/Postgres
# dependency, uncomment COMPOSE_PROFILES below and use the in-network
# service names instead (KAFKA_BOOTSTRAP_SERVERS=kafka:9092).
KAFKA_BOOTSTRAP_SERVERS=your_kafka_host:9092
KAFKA_TOPIC=vtuber.messages

# Uncomment to start the bundled local Kafka + Postgres services instead of
# pointing at an external instance (docker-compose.yml's `kafka`/`postgres`
# services, profile-gated so they never start otherwise):
COMPOSE_PROFILES=local-infra

# ── Redis (worker on/off control, docs/worker_control.md) ──────────────────────
# Optional — defaults to redis://redis:6379, the bundled `redis` service in
# docker-compose.yml. Only set this if pointing at a different Redis instance.
REDIS_URL=

# ── Postgres (message + container log logging) ─────────────────────────────────
# Dedicated role/database for this project — see docs/sql/ to create them.
POSTGRES_HOST=your_postgres_host
POSTGRES_PORT=5432
POSTGRES_DB=virtualtubers
POSTGRES_USER=virtualtubers
POSTGRES_PASSWORD=

# ── Avatar provider override (docs/avatar_providers.md) ─────────────────────────
# Per-worker avatar renderer override — "builtin" (default, always available)
# or "ascii_avatar" (animated, needs the repos/ascii-avatar image layer built
# in at least once). Leave blank to use each worker config's avatar.provider.
CODER_AVATAR_PROVIDER=
CODER_NATIVE_AVATAR_PROVIDER=
CODER_OPENCODE_AVATAR_PROVIDER=
CODER_AIDER_AVATAR_PROVIDER=
MANAGER_AVATAR_PROVIDER=
TESTER_AVATAR_PROVIDER=

# ── Layout preset override (docs/replay_pane.md, docs/layout_system.md) ─────────
# Switch a worker into "Rerun Theater" mode — set to "replay" to enable the
# replay pane so replay_request messages (docs/operator_commands.md) actually
# render; any other value (or blank) keeps each worker's default layout.
# Env-only change, no rebuild — but it replaces that worker's live pane
# (editor, etc.) for as long as it's set.
CODER_LAYOUT_PRESET=
MANAGER_LAYOUT_PRESET=
TESTER_LAYOUT_PRESET=
# A/B coding-backend coders (docs/coding_backend.md) — these three default to
# "replay" (Rerun Theater) for now; set to "coder" to switch one back to its
# normal editor pane.
CODER_NATIVE_LAYOUT_PRESET=
CODER_OPENCODE_LAYOUT_PRESET=
CODER_AIDER_LAYOUT_PRESET=

# ── Replay narration (docs/duet_replay.md, docs/revoice.md) ────────────────────
# How long a duet director waits for every cast worker to publish replay_ready
# before refusing the airing outright (docs/duet_replay.md's refusal rule).
# Blank keeps the code default (60 seconds).
REPLAY_READY_TIMEOUT_S=
# Testing-only: skip the LLM narration rewrite on a fresh replay airing and use
# the fallback/template narration instead (same path used when the LLM errors
# mid-show) — cuts a "preparing tonight's episode" pass from minutes to
# seconds. Set to 1/true on worker-coder, worker-manager, and worker-tester.
# Leave blank for normal (LLM-voiced) airings. Never affects a worker's real
# coding-task LLM use.
REPLAY_SKIP_LLM=
# Testing-only: override voice.provider (docs/tts_client.md). Set to "fake"
# to skip real TTS synthesis (no piper subprocess/model load) while still
# returning a real, duet-safe client with a proportional silent-WAV
# duration — combine with REPLAY_SKIP_LLM above for the fastest test prep.
# Leave blank to use each worker's configured provider (piper). Never leave
# set to "fake" for a real stream — no audio reaches the listener.
TTS_PROVIDER=
# Point Piper synthesis at a remote piper.http_server instead of running it
# in-container — e.g. once TTS moves onto a separate, more powerful machine
# (`python -m piper.http_server -m <model> --data-dir <dir with every
# persona's .onnx>`, then set this to that server's http://host:port).
# Blank/unset (default): synthesize locally, keeping one loaded model
# resident per worker process for its whole lifetime.
TTS_BASE_URL=

# ── Twitch presence (docs/twitch_presence.md) ───────────────────────────────────
# channel:worker_id pairs, e.g. "mycoderchannel:coder,mymgrchannel:manager"
# Idles with a periodic log line until this is set.
TWITCH_CHANNEL_MAP=
# Seconds before the same viewer in the same channel is greeted again
PRESENCE_COOLDOWN_S=3600
# Extra chat bots to ignore (extends the built-in list)
PRESENCE_IGNORE_USERS=

# ── Log retention (docs/log_shipper.md) ─────────────────────────────────────────
# container_logs rows older than this are purged hourly
LOG_RETENTION_DAYS=7
